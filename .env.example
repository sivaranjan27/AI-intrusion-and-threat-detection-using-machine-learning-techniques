# Email Configuration
# For Gmail: Create an App Password from Google Account Security
# https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Alternative: SMTP Configuration
# SMTP_HOST=smtp.provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@provider.com
# SMTP_PASS=your-password

# Admin Email (where attack alerts will be sent)
ADMIN_EMAIL=admin@yourcompany.com

# Google Gemini AI API Key (Optional - for enhanced chatbot)
# Get your key from: https://aistudio.google.com/app/apikeys
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Application
NEXT_PUBLIC_APP_NAME=Security Attack Detection
